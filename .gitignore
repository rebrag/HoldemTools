# Root .gitignore for the HoldemTools monorepo.
# Subfolders keep their own .gitignore (frontend/, backend/) — those still apply.
# This file only covers cross-cutting OS/editor junk and root-level files.

# OS / editor cruft (can appear in any folder)
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.swp

# Claude Code local, per-machine settings (never shared)
.claude/settings.local.json

# Root-level env / secrets (subfolders ignore their own .env already)
.env
.env.local
*.local

# Firebase emulator run artifacts (see "Firebase emulators" in CLAUDE.md).
# The committed config is firebase.json / .firebaserc / firebase/ — everything
# below is generated at runtime.
firebase-debug.log
firestore-debug.log
ui-debug.log
database-debug.log
pubsub-debug.log
.firebase/
