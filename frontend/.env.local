# Placeholder Firebase web config so the app BOOTS in fresh dev / Claude Code
# web sessions (a clone has no real .env, and firebase/auth throws
# "auth/invalid-api-key" on an empty config, which hard-crashes the whole app
# before anything renders). These are dummy values — good enough to initialise
# the SDK and work on the UI; they will NOT authenticate against real Firebase.
#
# Production is unaffected: Vercel injects the real VITE_FIREBASE_* values as
# build-time environment variables, and Vite gives process.env variables
# priority over .env files, so the real config always wins in deploys.
VITE_FIREBASE_API_KEY=AIzaSyDUMMYKEY_local_dev_only_1234567890
VITE_FIREBASE_AUTH_DOMAIN=gto-lite.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=gto-lite
VITE_FIREBASE_STORAGE_BUCKET=gto-lite.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
